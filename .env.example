# Spotify App Credentials (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Token Storage Location
TOKEN_STORAGE_PATH=~/.spotify-mcp/tokens.enc
