---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const featured = [
  {
    title: 'Dear World, We\'re Sorry — Love, Most of Us',
    prompt: 'An apology playlist from the Americans who are watching in horror — songs of remorse, solidarity, and stubborn hope',
    trackCount: 100,
    tracks: ['Marvin Gaye — What\'s Going On', 'Bob Dylan — Blowin\' in the Wind', 'Billie Holiday — Strange Fruit', 'Public Enemy — Fight the Power', 'Kendrick Lamar — Alright', 'Sam Cooke — A Change Is Gonna Come', 'Patti Smith — People Have the Power'],
    tags: ['Timely', '100 Tracks'],
    color: '#dc2626',
    url: 'https://open.spotify.com/playlist/2orIfaPVOb4DqV1xD3GF01',
  },
  {
    title: 'Songs That Need No Translation',
    prompt: 'Music in every language that hits you in the chest — fado, qawwali, bossa nova, throat singing. Emotion is universal.',
    trackCount: 25,
    tracks: ['Fairuz — Bint El Shalabiya', 'Miriam Makeba — Malaika', 'Buena Vista Social Club — Chan Chan', 'Edith Piaf — La Vie en Rose', 'Gipsy Kings — Bamboleo', 'Sergio Mendes — Mas Que Nada'],
    tags: ['World', 'Cross-Cultural'],
    color: '#0ea5e9',
    url: 'https://open.spotify.com/playlist/0NN5naxbctqXy6wMLxjUcW',
  },
  {
    title: 'The Beautiful Futility',
    prompt: 'Songs about pushing boulders uphill — Sisyphus vibes, futile struggle turned beautiful',
    trackCount: 56,
    tracks: ['Kate Bush — Running Up That Hill', 'Jeff Buckley — Hallelujah', 'Coldplay — Fix You', 'Johnny Cash — Hurt', 'Sigur Ros — Hoppipolla', 'Arcade Fire — Wake Up', 'The Verve — Bitter Sweet Symphony'],
    tags: ['Thematic', 'Literary'],
    color: '#8b5cf6',
    url: 'https://open.spotify.com/playlist/0Hc07yRYtfEdsvPGXM0ZU0',
  },
  {
    title: 'From Smoke to Circuits',
    prompt: 'Jazz-to-electronic pipeline — start mellow, end cosmic',
    trackCount: 40,
    tracks: ['Miles Davis — So What', 'Nina Simone — Feeling Good', 'Massive Attack — Teardrop', 'DJ Shadow — Midnight in a Perfect World', 'Boards of Canada — Dayvan Cowboy', 'Burial — Archangel', 'ODESZA — A Moment Apart'],
    tags: ['Era Blend', 'Narrative Arc'],
    color: '#3b82f6',
    url: 'https://open.spotify.com/playlist/5zprYcSu5pd4sLpbgPEms5',
  },
  {
    title: 'Songs for When God is Talking',
    prompt: 'Music that feels like a conversation with the divine — songs that make you pull your car over and just sit there',
    trackCount: 25,
    tracks: ['Aretha Franklin — Amazing Grace', 'Kanye West — Ultralight Beam', 'Leonard Cohen — Hallelujah', 'Curtis Mayfield — People Get Ready', 'Edwin Hawkins — Oh Happy Day', 'Madonna — Like a Prayer'],
    tags: ['Spiritual', 'Transcendent'],
    color: '#eab308',
    url: 'https://open.spotify.com/playlist/3i8NdN9QN4PZrv7D8uy1nl',
  },
  {
    title: 'Songs That Hit Different at 2AM Alone',
    prompt: 'The playlist you put on when everyone else is asleep and you\'re staring at the ceiling thinking about everything',
    trackCount: 25,
    tracks: ['Bon Iver — Skinny Love', 'Radiohead — No Surprises', 'Mazzy Star — Fade Into You', 'Beach House — Space Song', 'Sufjan Stevens — Death With Dignity', 'Phoebe Bridgers — Motion Sickness'],
    tags: ['Relatable', 'Late Night'],
    color: '#6366f1',
    url: 'https://open.spotify.com/playlist/4vEMi6JmCUt2EZXgJHARLY',
  },
  {
    title: 'Mount Olympus Has a Jukebox',
    prompt: 'Songs referencing Greek mythology — gods, heroes, and mortals',
    trackCount: 45,
    tracks: ['Led Zeppelin — Achilles Last Stand', 'Fleetwood Mac — Rhiannon', 'Iron Maiden — Flight of Icarus', 'Hozier — Take Me to Church', 'Weyes Blood — Andromeda', 'Echo & the Bunnymen — The Killing Moon'],
    tags: ['Thematic', 'Mythology'],
    color: '#f59e0b',
    url: 'https://open.spotify.com/playlist/3EYdOzTlNxPufaqYD0KvzA',
  },
  {
    title: 'Dedications After Dark',
    prompt: 'Songs you\'d call into the radio at midnight to dedicate to someone special — 80s and 90s power ballads',
    trackCount: 28,
    tracks: ['Whitney Houston — I Will Always Love You', 'Foreigner — I Want to Know What Love Is', 'Peter Gabriel — In Your Eyes', 'Bon Jovi — Always', 'Savage Garden — Truly Madly Deeply', 'George Michael — Careless Whisper'],
    tags: ['Nostalgia', 'Romance'],
    color: '#f472b6',
    url: 'https://open.spotify.com/playlist/72aLljhEklybrBBmkleOVc',
  },
];

const allPlaylists = [
  { title: 'Quiet Defiance', url: 'https://open.spotify.com/playlist/334mgsZ9xoEFtiAGLpl4ff', desc: 'Dignity as resistance. Hope as rebellion.' },
  { title: 'Songs for Parents Who Are Tired but Trying', url: 'https://open.spotify.com/playlist/55r0ZYvxp1lT0bSyTARYUd', desc: 'You showed up again today and that matters.' },
  { title: 'Songs for Doomscrolling Recovery', url: 'https://open.spotify.com/playlist/2N8n9W2SJmNQAQXTpwZOFb', desc: 'Put the phone down. These songs bring you back.' },
  { title: 'Songs for When You Finally Set a Boundary', url: 'https://open.spotify.com/playlist/3RD1ygSdmU3MbzSckAeAQo', desc: 'You said no. You meant it. You feel free.' },
  { title: 'Songs That Feel Like a Hug', url: 'https://open.spotify.com/playlist/3dqmhpDY9HlZFZTChNPvZM', desc: 'Someone sitting with you saying "yeah, I know."' },
  { title: 'Songs Your Therapist Would Be Proud Of', url: 'https://open.spotify.com/playlist/4XarDt2h9SSnfMangDu49v', desc: 'Boundary-setting anthems and self-compassion ballads.' },
  { title: 'Songs That Make Atheists Pray', url: 'https://open.spotify.com/playlist/58AM2ZOmwxhnjG2EuMgpQo', desc: 'Music that breaks through every wall.' },
  { title: 'Songs You Didn\'t Know You Needed to Cry To', url: 'https://open.spotify.com/playlist/2b4oVzBsMfbCNOOmaRgHVr', desc: 'You weren\'t even sad. Then this song came on.' },
  { title: 'Songs for the Main Character Moment', url: 'https://open.spotify.com/playlist/5F78EDRht9Y7g00TUKRKtQ', desc: 'Walking in slow motion. Wind in your hair.' },
  { title: 'The Villain\'s Playlist', url: 'https://open.spotify.com/playlist/5oOUvaehaBNWHScnjA2vx1', desc: 'Every villain needs a soundtrack.' },
  { title: 'If Historical Figures Had Walkout Songs', url: 'https://open.spotify.com/playlist/1I2Xx3drypsj6bCW0lr8RW', desc: 'Entrance music for legends.' },
  { title: 'Songs That Sound Like Colors', url: 'https://open.spotify.com/playlist/2J4jg2S9c80OMFZgk1dMRg', desc: 'A synesthesia playlist — each track IS a color.' },
  { title: 'The World Is Grieving Together', url: 'https://open.spotify.com/playlist/4lx24L0eaL2lcOjsJE0jMd', desc: 'Songs of collective sorrow from every continent.' },
  { title: 'Midnight Kitchen Music', url: 'https://open.spotify.com/playlist/2JE6PzGrN4BqrqIyrSrEJr', desc: '3am, can\'t sleep, making tea in a dark kitchen.' },
  { title: 'Letters To Who I Used To Be', url: 'https://open.spotify.com/playlist/1M9NOB9aHVmZ3noomiO8qc', desc: 'Songs where the narrator talks to their past self.' },
  { title: 'The Musical Argument', url: 'https://open.spotify.com/playlist/0ydq9BDALW3e5rz9u0gcw7', desc: 'Songs two rivals play at each other.' },
  { title: '3AM at the Diner', url: 'https://open.spotify.com/playlist/3oSj722cI7kYIiE3aMm4kJ', desc: 'Lonely but not sad, warm coffee and neon lights.' },
  { title: 'Soundtrack to a Film That Doesn\'t Exist', url: 'https://open.spotify.com/playlist/4ciTEFQSZR0RpvcltVGUom', desc: 'Cinematic instrumentals for an imaginary film.' },
  { title: 'Songs That Should Have Been Hits', url: 'https://open.spotify.com/playlist/1TeJyY9H7QpWB8CAwn45Gy', desc: 'Deep cuts from legendary artists.' },
];
---

<Base
  title="Example Playlists"
  description="27 AI-curated playlists that no algorithm could imagine. From 100-track apologies to the world, to songs that need no translation. Listen on Spotify."
>
  <Header />
  <main id="main-content" class="examples-page">
    <div class="container">
      <span class="section-label">Showcase</span>
      <h1>Example Playlists</h1>
      <p class="intro">27 playlists created by Claude using the Spotify MCP Server. Each one started as a single sentence. Every playlist is public — click to listen.</p>

      <div class="stats-bar">
        <div class="stat-item"><strong>27</strong> playlists</div>
        <div class="stat-item"><strong>750+</strong> tracks</div>
        <div class="stat-item"><strong>20+</strong> genres</div>
        <div class="stat-item"><strong>6</strong> continents</div>
      </div>

      <h2 class="section-heading">Featured</h2>
      <div class="gallery">
        {featured.map((playlist, i) => (
          <div class="playlist-card" style={`--card-accent: ${playlist.color}`}>
            <div class="card-accent-line" aria-hidden="true"></div>
            <div class="playlist-header">
              <div>
                <h2>{playlist.title}</h2>
              </div>
              <div class="header-right">
                <span class="track-count">{playlist.trackCount} tracks</span>
                <div class="tags">
                  {playlist.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <a href={playlist.url} target="_blank" rel="noopener noreferrer" class="spotify-link" aria-label={`Listen to ${playlist.title} on Spotify`}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                  </svg>
                  Listen
                </a>
              </div>
            </div>
            <blockquote>"{playlist.prompt}"</blockquote>
            <div class="track-list">
              <h3>Sample Tracks</h3>
              <ol>
                {playlist.tracks.map((track) => {
                  const parts = track.split(' — ');
                  return (
                    <li>
                      <span class="track-artist">{parts[0]}</span>
                      <span class="track-sep">—</span>
                      <span class="track-name">{parts[1]}</span>
                    </li>
                  );
                })}
              </ol>
            </div>
          </div>
        ))}
      </div>

      <hr class="glow-line" />

      <h2 class="section-heading">All Playlists</h2>
      <p class="all-intro">Every playlist Claude created — click any to listen on Spotify.</p>
      <div class="all-grid">
        {allPlaylists.map((p) => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="all-card">
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <span class="listen-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
              </svg>
              Listen on Spotify
            </span>
          </a>
        ))}
      </div>

      <hr class="glow-line" />

      <div class="cta-block">
        <h2>Create your own</h2>
        <p>Set up the Spotify MCP Server and tell Claude what you want to hear.</p>
        <a href="/setup" class="btn btn-primary">
          Get Started
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .examples-page {
    padding: 4rem 0;
  }

  .examples-page h1 {
    margin-bottom: 0.75rem;
  }

  .intro {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .stats-bar {
    display: flex;
    gap: 2rem;
    padding: 1rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .stat-item {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .stat-item strong {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 1.1rem;
  }

  .section-heading {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .gallery {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .playlist-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s var(--ease-out);
  }

  .playlist-card:hover {
    border-color: var(--card-accent, var(--border));
  }

  .card-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--card-accent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .playlist-card:hover .card-accent-line {
    opacity: 1;
  }

  .playlist-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .playlist-header h2 {
    font-size: 1.35rem;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .track-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .tags {
    display: flex;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.65rem;
    border-radius: 6px;
    background: var(--bg-elevated);
    color: var(--text-muted);
    font-weight: 500;
    border: 1px solid var(--border);
  }

  .spotify-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #1DB954;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(29, 185, 84, 0.1);
    border: 1px solid rgba(29, 185, 84, 0.2);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .spotify-link:hover {
    background: rgba(29, 185, 84, 0.2);
    color: #1ed760;
  }

  blockquote {
    color: var(--text-secondary);
    font-style: italic;
    font-size: 1rem;
    padding-left: 1rem;
    border-left: 2px solid var(--card-accent, var(--accent));
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .track-list {
    background: var(--bg-surface);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .track-list h3 {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .track-list ol {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .track-list li {
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .track-artist {
    color: var(--text);
    font-weight: 500;
  }

  .track-sep {
    color: var(--text-muted);
  }

  .track-name {
    color: var(--text-muted);
  }

  /* All Playlists Grid */
  .all-intro {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .all-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .all-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: all 0.25s var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
  }

  .all-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .all-card h3 {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.3;
  }

  .all-card p {
    color: var(--text-muted);
    font-size: 0.825rem;
    line-height: 1.5;
    flex-grow: 1;
  }

  .listen-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #1DB954;
    margin-top: 0.25rem;
  }

  .cta-block {
    text-align: center;
    padding: 4rem 0 2rem;
  }

  .cta-block h2 {
    margin-bottom: 0.75rem;
  }

  .cta-block p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .examples-page { padding: 3rem 0; }
    .intro { font-size: 0.95rem; }
    .stats-bar { gap: 1rem; padding: 0.85rem 1rem; }
    .stat-item { font-size: 0.8rem; }
    .gallery { gap: 1rem; }
    .playlist-card { padding: 1.25rem; border-radius: 12px; }
    .playlist-card:hover { transform: none; box-shadow: none; }
    .playlist-header { flex-direction: column; gap: 0.5rem; }
    .playlist-header h2 { font-size: 1.15rem; }
    .header-right { gap: 0.5rem; }
    .track-count { font-size: 0.7rem; }
    .tag { font-size: 0.6rem; padding: 0.15rem 0.5rem; }
    .spotify-link { font-size: 0.7rem; padding: 0.3rem 0.6rem; }
    blockquote { font-size: 0.875rem; padding-left: 0.75rem; margin-bottom: 1rem; }
    .track-list { padding: 1rem; border-radius: 10px; }
    .track-list li { font-size: 0.8rem; }
    .all-grid { grid-template-columns: 1fr; }
    .all-card { padding: 1rem; }
    .cta-block { padding: 2.5rem 0 1rem; }
  }

  @media (max-width: 480px) {
    .playlist-card { padding: 1rem; }
    .playlist-header h2 { font-size: 1.05rem; }
    .track-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }
    .track-sep { display: none; }
    .track-name { font-size: 0.75rem; }
  }
</style>
