{
  "name": "spotify-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that lets Claude create Spotify playlists through natural language",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": ["mcp", "spotify", "claude", "playlist", "ai"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "open": "^10.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
