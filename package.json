{
  "name": "spotify-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that lets Claude create Spotify playlists through natural language",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spotify-mcp-server": "dist/index.js"
  },
  "author": "WisetechySolutions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WisetechySolutions/spotify-mcp-server.git"
  },
  "homepage": "https://github.com/WisetechySolutions/spotify-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/WisetechySolutions/spotify-mcp-server/issues"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": ["mcp", "spotify", "claude", "playlist", "ai", "music", "curation"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
